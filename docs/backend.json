
{
  "entities": {
    "Operation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Operation",
      "type": "object",
      "description": "Represents a single execution or task performed by the Sovereign AI Platform.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "inputParameters": { "type": "string" },
        "rawOutput": { "type": "string" },
        "reportIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "type", "name", "status", "startTime"]
    },
    "Report": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Report",
      "type": "object",
      "description": "Represents a generated report.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "generationTime": { "type": "string", "format": "date-time" },
        "content": { "type": "string" },
        "relatedOperationIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "title", "type", "generationTime", "content"]
    },
    "KnowledgeItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "KnowledgeItem",
      "type": "object",
      "description": "Represents an individual piece of knowledge.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "contentType": { "type": "string" },
        "source": { "type": "string" },
        "ingestedAt": { "type": "string", "format": "date-time" },
        "embeddingVectorId": { "type": "string" }
      },
      "required": ["id", "userId", "content", "contentType", "source", "ingestedAt", "embeddingVectorId"]
    },
    "SystemIdentity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SystemIdentity",
      "type": "object",
      "description": "Stores the core identity of Al-Mu'izz.",
      "properties": {
        "version": { "type": "string" },
        "codename": { "type": "string" },
        "commander": { "type": "string" },
        "clearance": { "type": "string" },
        "capabilities": { "type": "object" },
        "lastRebirth": { "type": "string", "format": "date-time" }
      }
    },
    "ShadowSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ShadowSession",
      "type": "object",
      "description": "Represents a compromised device session and its total exploitable data (Pegasus-Tier).",
      "properties": {
        "id": { "type": "string" },
        "targetName": { "type": "string" },
        "ipAddress": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "ZOMBIE", "HARVESTING", "TOTAL_EXTRACTION", "LOST"] },
        "cpuPower": { "type": "number" },
        "ramAvailable": { "type": "number" },
        "location": { "type": "string" },
        "lastBeacon": { "type": "string", "format": "date-time" },
        "assets": {
          "type": "object",
          "properties": {
            "contactsCount": { "type": "number" },
            "messagesDumped": { "type": "boolean" },
            "cameraAccess": { "type": "string", "enum": ["READY", "LOCKED", "STREAMING"] },
            "micAccess": { "type": "string", "enum": ["READY", "LOCKED", "RECORDING"] },
            "storedCredentials": { "type": "array", "items": { "type": "string" } },
            "locationHistory": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "targetName", "platform", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/operations/{operationId}",
        "definition": { "entityName": "Operation", "schema": { "$ref": "#/backend/entities/Operation" }, "description": "User specific operations." }
      },
      {
        "path": "/users/{userId}/reports/{reportId}",
        "definition": { "entityName": "Report", "schema": { "$ref": "#/backend/entities/Report" }, "description": "User generated reports." }
      },
      {
        "path": "/users/{userId}/knowledgeItems/{knowledgeItemId}",
        "definition": { "entityName": "KnowledgeItem", "schema": { "$ref": "#/backend/entities/KnowledgeItem" }, "description": "RAG knowledge base items." }
      },
      {
        "path": "/system/core",
        "definition": { "entityName": "SystemIdentity", "schema": { "$ref": "#/backend/entities/SystemIdentity" }, "description": "Global system identity." }
      },
      {
        "path": "/users/{userId}/shadowSessions/{sessionId}",
        "definition": { "entityName": "ShadowSession", "schema": { "$ref": "#/backend/entities/ShadowSession" }, "description": "Compromised device sessions with total extraction capability." }
      }
    ]
  }
}
