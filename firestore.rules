
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SOVEREIGN AI PLATFORM v20.5 - SECURITY RULES
     * PROGENY MODULE INTEGRATED
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isValidOwnershipCreation(userId) {
      return request.resource.data.userId == userId;
    }

    match /users/{userId}/operations/{operationId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidOwnershipCreation(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/reports/{reportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidOwnershipCreation(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/knowledgeItems/{knowledgeItemId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidOwnershipCreation(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/shadowSessions/{sessionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/progeny/{progenyId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /system/core {
      allow get: if isSignedIn();
      allow write: if false; 
    }

    match /aiModelConfigurations/{modelConfigId} {
      allow get, list: if isSignedIn();
    }

    match /toolDefinitions/{toolDefinitionId} {
      allow get, list: if isSignedIn();
    }

  }
}
